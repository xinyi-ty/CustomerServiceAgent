# ====================
# 大模型 API 配置
# ====================

# 智谱 AI (GLM-4-Flash) 配置
# 获取 API Key: https://open.bigmodel.cn/
LLM_API_KEY=your_zhipu_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
LLM_MODEL_NAME=glm-4-flash

# 如果使用通义千问，取消下面注释并注释上面的配置
# LLM_API_KEY=your_qwen_api_key_here
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-turbo

# ====================
# 数据库配置
# ====================

# SQLite 数据库文件路径（相对于 backend/ 目录）
DATABASE_PATH=./data/tickets.db

# ====================
# 文件上传配置
# ====================

# 临时文件上传目录
UPLOAD_DIR=./uploads

# 上传文件大小限制（MB）
MAX_FILE_SIZE_MB=10

# ====================
# 服务配置
# ====================

# 后端服务端口
SERVER_PORT=8000

# 是否启用调试模式（true/false）
DEBUG_MODE=true

# ====================
# OCR 配置（可选）
# ====================

# PaddleOCR 使用 CPU 还是 GPU（cuda/cpu）
OCR_DEVICE=cpu

# ====================
# 保修校验配置（可选）
# ====================

# 保修年限（默认 2 年）
WARRANTY_YEARS=2
