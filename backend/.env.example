# ========== 环境标识 ==========
ENV=development

# ========== 大模型 API 配置（必需）==========
# 支持任何兼容 OpenAI API 格式的服务（DeepSeek、Qwen、GLM 等）
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-chat

# ========== RAG 向量检索 API 配置（必需）==========
# 用于 SOP 知识库向量化（Embedding），DashScope 阿里云百炼
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ========== 服务配置 ==========
HOST=0.0.0.0
PORT=8000

# ========== 数据库与存储 ==========
DATABASE_PATH=./data/tickets.db
UPLOAD_DIR=./uploads

# ========== ERP 系统配置（可选）==========
# 不配置则自动降级为本地 SN 码规则模拟
ERP_API_URL=
ERP_API_KEY=
